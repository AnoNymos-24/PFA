# ════════════════════════════════════════════════════════════════════════
# SmartInternIA2 — Backend Spring Boot — Variables d'environnement
# Copiez ce fichier en .env et renseignez les valeurs réelles.
# NE JAMAIS committer le fichier .env avec des valeurs réelles.
# ════════════════════════════════════════════════════════════════════════

# ── Serveur ───────────────────────────────────────────────────────────────
SERVER_PORT=8081

# ── Base de données MySQL ─────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/smartintern_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=

# ── JWT — OBLIGATOIRE EN PRODUCTION ──────────────────────────────────────
# Générer avec : openssl rand -hex 64
JWT_SECRET=remplacez-par-une-cle-aleatoire-dau-moins-32-caracteres
JWT_EXPIRATION=86400000

# ── Gmail SMTP — OBLIGATOIRE POUR LES EMAILS ─────────────────────────────
# Créer un mot de passe d'application sur https://myaccount.google.com/apppasswords
GMAIL_USERNAME=votre-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Microservice Python ───────────────────────────────────────────────────
CV_SERVICE_URL=http://localhost:8000

# ── Frontend ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5500

# ── Debug (désactiver en production) ─────────────────────────────────────
JPA_SHOW_SQL=false
