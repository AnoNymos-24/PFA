# ── SmartIntern AI — CV Service ──────────────────────────────
# Copier ce fichier en .env et renseigner les valeurs

# Clé API Anthropic (obligatoire)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Port du service (optionnel, défaut: 8000)
CV_SERVICE_PORT=8000

# Hôte (optionnel, défaut: 0.0.0.0)
CV_SERVICE_HOST=0.0.0.0
