# ════════════════════════════════════════════════════════════════════════
# SmartInternIA2 — Microservice Python — Variables d'environnement
# Copiez ce fichier en .env et renseignez les valeurs réelles.
# NE JAMAIS committer le fichier .env avec des valeurs réelles.
# ════════════════════════════════════════════════════════════════════════

# ── Provider IA PRIMAIRE : Anthropic Direct ──────────────────────────────
# Clé obtenue sur https://console.anthropic.com/settings/keys
# Si renseignée, Anthropic sera utilisé en premier.
ANTHROPIC_API_KEY=sk-ant-votre-cle-anthropic-ici
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Provider IA FALLBACK : OpenRouter ────────────────────────────────────
# Clé obtenue sur https://openrouter.ai/keys
# Utilisé automatiquement si Anthropic retourne une erreur de quota/tokens.
# Peut aussi être utilisé seul (sans clé Anthropic) — il devient alors le primaire.
OPENROUTER_API_KEY=sk-or-v1-votre-cle-openrouter-ici
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# ── Comportement du fallback ──────────────────────────────────────────────
# Le basculement se fait automatiquement sur les erreurs :
#   - 429 Rate Limit (quota dépassé)
#   - 402 Insufficient credits
#   - 529 API overloaded
#   - Erreurs de type "context_length_exceeded", "token limit", etc.
# Aucune configuration supplémentaire n'est nécessaire.

# ── Serveur ───────────────────────────────────────────────────────────────
CV_SERVICE_PORT=8000
BASE_URL=http://localhost:8000

# ── Sécurité HMAC — OBLIGATOIRE EN PRODUCTION ────────────────────────────
# Doit correspondre à la valeur utilisée par le backend Java si vérification croisée
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SIGNATURE_SECRET=SmartIntern_SecretKey_ChangezMoi_En_Production
