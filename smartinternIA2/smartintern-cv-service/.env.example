# ── SmartIntern AI — CV Extraction & Document Service ──────────────────────
# Copiez ce fichier en .env et renseignez vos valeurs

# Clé API Anthropic (OBLIGATOIRE — https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Port et hôte du service
CV_SERVICE_PORT=8000
CV_SERVICE_HOST=0.0.0.0

# URL de base (pour les QR codes et liens de vérification)
BASE_URL=http://localhost:8000

# Clé secrète pour la signature HMAC des documents
# Changez cette valeur en production !
SIGNATURE_SECRET=SmartIntern_SecretKey_ChangezMoi_2024
